@{
    ViewData["Title"] = "Rider Reports - SafeGuard App";
}

<section class="page-heading">
    <div>
        <h1>Report Incident</h1>
        <p>Send safety concerns with route, location, optional media, and a short description.</p>
    </div>
</section>

<section class="settings-grid" id="new-report">
    <article class="panel">
        <div class="panel-header compact"><div><h2>New report</h2></div></div>
        <form class="incident-form" data-rider-report-form>
            <label>Risk Type
                <select name="riskType" data-rider-risk required></select>
            </label>
            <label>Description
                <textarea name="details" rows="4" placeholder="Describe what you saw or heard." required></textarea>
            </label>
            <label>Route
                <input name="route" value="54 Lawrence East" required />
            </label>
            <label>Bus ID
                <input name="busId" value="3700" required />
            </label>
            <label>Location
                <input name="location" value="Lawrence Ave E & Morningside Ave" required data-location-address />
            </label>
            <div class="location-tool" data-location-picker>
                <button class="ghost-button" type="button" data-locate-current>
                    <img src="~/icons/map-pin.svg" alt="" />
                    Use Live Location
                </button>
                <span data-location-status>Location not captured.</span>
                <input type="hidden" name="latitude" data-location-lat />
                <input type="hidden" name="longitude" data-location-lng />
                <input type="hidden" name="locationAccuracy" data-location-accuracy />
                <input type="hidden" name="locationSource" data-location-source />
                <div class="google-map" data-location-map hidden></div>
            </div>
            <label>Vehicle Area
                <select name="vehicleArea">
                    <option>Front cabin</option>
                    <option>Rear doors</option>
                    <option>Middle section</option>
                    <option>Bus stop / platform</option>
                </select>
            </label>
            <div class="voice-recorder" data-voice-recorder>
                <div>
                    <strong>Voice Note</strong>
                    <small>Record a short audio note for the operator.</small>
                </div>
                <div class="voice-controls">
                    <button class="ghost-button" type="button" data-voice-start>Record</button>
                    <button class="ghost-button" type="button" data-voice-stop disabled>Stop</button>
                    <button class="ghost-button" type="button" data-voice-clear disabled>Clear</button>
                </div>
                <audio controls preload="none" data-voice-playback hidden></audio>
                <span data-voice-status>No voice note recorded.</span>
            </div>
            <label>Attach Media
                <input type="file" name="mediaFiles" data-media-upload multiple accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.txt" />
            </label>
            <p class="upload-help">Attach photos, short videos, audio clips, PDFs, notes, or a recorded voice note. Maximum 50 MB per file.</p>
            <div class="media-preview" data-media-preview><small>No files selected.</small></div>
            <div class="form-actions">
                <button class="primary-button" type="submit">Submit Report</button>
                <button class="ghost-button" type="reset">Reset</button>
            </div>
        </form>
    </article>

    <article class="panel">
        <div class="panel-header compact"><div><h2>What happens next</h2></div></div>
        <ul class="activity-log">
            <li>Report is sent to an operator for review.</li>
            <li>Operator checks the risk type, location, audio, and media.</li>
            <li>Real risks are escalated to Admin or Management.</li>
            <li>False or duplicate reports are closed after validation.</li>
        </ul>
    </article>
</section>

<section class="panel">
    <div class="panel-header">
        <div><h2>My reports</h2></div>
        <span class="pill" data-rider-report-count>0 reports</span>
    </div>
    <div class="filter-bar" aria-label="Rider report filters">
        <label>Status
            <select data-rider-status-filter>
                <option value="All">All</option>
                <option value="Pending">Pending</option>
                <option value="Acknowledged">Acknowledged</option>
                <option value="Escalated">Escalated</option>
                <option value="Closed">Closed</option>
            </select>
        </label>
    </div>
    <div class="table-wrap">
        <table class="data-table" aria-label="Rider submitted reports">
            <thead><tr><th>Time</th><th>Status</th><th>Risk Type</th><th>Route / Bus</th><th>Location</th><th>Details</th></tr></thead>
            <tbody data-rider-report-list></tbody>
        </table>
    </div>
</section>

@section Scripts {
    <script src="~/js/operator-data.js" asp-append-version="true"></script>
    <script src="~/js/rider-reports.js" asp-append-version="true"></script>
}
